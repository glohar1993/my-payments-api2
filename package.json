{
  "name": "my-payments-api2",
  "version": "1.0.0",
  "description": "my-payments-api2 microservice",
  "main": "dist/handler.js",
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=test/handler",
    "test:infra": "jest --testPathPattern=infra/test/",
    "lint": "eslint 'src/**/*.ts' 'infra/**/*.ts'",
    "cdk:synth": "npx cdk synth",
    "cdk:deploy": "npx cdk deploy --require-approval never",
    "cdk:destroy": "npx cdk destroy --force",
    "cdk:diff": "npx cdk diff",
    "deploy:dev": "ENV=dev bash scripts/deploy.sh",
    "deploy:staging": "ENV=staging bash scripts/deploy.sh",
    "deploy:prod": "ENV=production bash scripts/deploy.sh"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/lib-dynamodb": "^3.500.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.130.0",
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.3.0",
    "@types/aws-lambda": "^8.10.131",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test",
      "<rootDir>/infra/test"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}